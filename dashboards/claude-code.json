{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Claude Code OTLP telemetry — metrics from Prometheus, events from Loki, traces from Tempo.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "id": 100
    },
    {
      "type": "stat",
      "title": "Sessions (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(claude_code_session_count_total[24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "Cost — today",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(claude_code_cost_usage_USD_total[24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "currencyUSD", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 25 } ] } }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "Cost — 7d",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(claude_code_cost_usage_USD_total[7d]))"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "currencyUSD", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "Tokens — 24h",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(claude_code_token_usage_tokens_total[24h]))"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "purple", "value": null } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "Active time — 24h",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(claude_code_active_time_total_seconds_total[24h]))"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "Lines net (added − removed, 24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(claude_code_lines_of_code_count_total{type=\"added\"}[24h])) - sum(increase(claude_code_lines_of_code_count_total{type=\"removed\"}[24h]))"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0 } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false } }
    },
    {
      "type": "row",
      "title": "Cost & tokens",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "id": 101
    },
    {
      "type": "timeseries",
      "title": "Cost USD — by model",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model) (rate(claude_code_cost_usage_USD_total[5m]))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Tokens — by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Cost — by query_source",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (query_source) (rate(claude_code_cost_usage_USD_total[5m]))",
          "legendFormat": "{{query_source}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "line", "fillOpacity": 20 } } }
    },
    {
      "type": "stat",
      "title": "Cache hit ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 14 },
      "id": 13,
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[1h])) / clamp_min(sum(rate(claude_code_token_usage_tokens_total{type=~\"input|cacheRead\"}[1h])), 1)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "green", "value": 0.8 } ] } } },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false } }
    },
    {
      "type": "stat",
      "title": "Edit accept rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 14 },
      "id": 14,
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(claude_code_code_edit_tool_decision_count_total{decision=\"accept\"}[24h])) / clamp_min(sum(rate(claude_code_code_edit_tool_decision_count_total[24h])), 1)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "green", "value": 0.85 } ] } } },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false } }
    },
    {
      "type": "row",
      "title": "Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false,
      "id": 102
    },
    {
      "type": "timeseries",
      "title": "Lines added vs removed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 20,
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (rate(claude_code_lines_of_code_count_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 } } }
    },
    {
      "type": "timeseries",
      "title": "Commits / PRs",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(claude_code_commit_count_total[1h]))",
          "legendFormat": "commits/hr"
        },
        {
          "refId": "B",
          "expr": "sum(rate(claude_code_pull_request_count_total[1h]))",
          "legendFormat": "PRs/hr"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20 } } }
    },
    {
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false,
      "id": 103
    },
    {
      "type": "logs",
      "title": "Recent prompts",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "id": 30,
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"claude-code\"} | json | attributes_event_name=\"user_prompt\" | line_format \"{{.attributes_prompt}}\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "type": "logs",
      "title": "Tool decisions",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 42 },
      "id": 31,
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"claude-code\"} | json | attributes_event_name=\"tool_decision\" | line_format \"{{.attributes_decision}} {{.attributes_source}} {{.attributes_tool_name}}\""
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "type": "logs",
      "title": "API errors",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 42 },
      "id": 32,
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"claude-code\"} | json | attributes_event_name=\"api_error\" | line_format \"{{.attributes_status_code}} {{.attributes_error}}\""
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "type": "row",
      "title": "Traces",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 },
      "collapsed": false,
      "id": 104
    },
    {
      "type": "traces",
      "title": "Recent interactions (Tempo)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 53 },
      "id": 40,
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{ resource.service.name=\"claude-code\" && name=\"claude_code.interaction\" } | select(interaction.duration_ms, user_prompt_length)"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [ "claude-code", "otel" ],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Claude Code",
  "uid": "claude-code",
  "version": 1,
  "weekStart": ""
}
