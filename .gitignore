# Secrets and keys
*.env
*.key
*.pem
id_*
!id_*.pub

# Nix build artifacts
result
result-*

# Go build artifacts — `go build` without -o drops a binary named after the
# package directory into that directory.
pkgs/*-mcp/*-mcp
!pkgs/*-mcp/*-mcp/

# Editor/OS artifacts
.direnv/
.DS_Store
*.swp
*.swo
*~

# Claude Code runtime files
.claude/scheduled_tasks.lock
pkgs/hermes-plugin-spend/__pycache__/

# Antigravity CLI runtime (symlinks into ~/.gemini/config/projects state)
.antigravitycli/
